    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.18.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.2",
    "nitro": "3.0.260603-beta",
    "tailwindcss": "^4.1.0",
